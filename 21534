t=int(input())

for i in range(t):
	b=[]
	n=int(input())
	if n%2==0:
		for i in range(1,n+1):
			if i%2!=0:
				b.append(i+1)
				b.append(i)
	else:
		for i in range(1,n-2):
			if i%2!=0:
				b.append(i+1)
				b.append(i)
		for i in range(1):
			b.append(n)
			b.append(n-2)
			b.append(n-1)
	print(*b)
	
			
